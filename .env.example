# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# ID администраторов (через запятую)
ADMIN_IDS=123456789,987654321

# ID модераторов (через запятую)
MODERATOR_IDS=111111111,222222222

# WebApp Settings (Mini App)
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=443
WEBAPP_URL=https://3face.xyz

# SSL сертификаты для HTTPS
SSL_CERT_PATH=3face.xyz/certificate.crt
SSL_KEY_PATH=3face.xyz/newkey.key

# GitHub репозиторий для автообновления (формат: username/repo)
GITHUB_REPO=LecYA07/3face-3.0
GITHUB_BRANCH=master

# OpenAI API для автопроверки результатов матчей
# Получить токен: используется кастомный API https://api.onlysq.ru/ai/openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.onlysq.ru/ai/openai
OPENAI_MODEL=gpt-4.1-mini

# AI Verification Settings
# true/false - включить/выключить AI проверку
AI_VERIFICATION_ENABLED=true
# Порог уверенности для автоподтверждения (0.0-1.0)
# При confidence >= этого значения результат может быть автоматически применён
AI_AUTO_APPROVE_CONFIDENCE=0.95

# ID администратора для получения AI отчётов о проверке матчей
# Если указан - отчёты будут приходить только этому админу
# Если не указан или 0 - отчёты будут приходить всем админам и модераторам
AI_REPORT_ADMIN_ID=0
